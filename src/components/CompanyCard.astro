---
import StarRating from './StarRating.astro';
import type { Company } from '../data/companies';

interface Props {
  company: Company;
}
const { company } = Astro.props;

const initials = company.name
  .split(' ')
  .map((w: string) => w[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

const displayBadges = company.badges.slice(0, 3);
const extraCount = company.badges.length - 3;
---

<article class="bg-white border border-slate-200 rounded-xl p-5 flex flex-col hover:shadow-md hover:border-brand-300 transition-all duration-150">

  <!-- Logo + name row -->
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex items-center gap-3 min-w-0">
      <div class="w-10 h-10 rounded-lg bg-brand-100 text-brand-700 flex items-center justify-center font-bold text-sm shrink-0 select-none">
        {initials}
      </div>
      <div class="min-w-0">
        <h3 class="font-semibold text-slate-900 leading-tight truncate">{company.name}</h3>
        <p class="text-xs text-slate-500 mt-0.5">{company.hq} · Est. {company.founded}</p>
      </div>
    </div>
    {company.featured && (
      <span class="text-xs bg-brand-600 text-white px-2 py-0.5 rounded font-medium shrink-0 leading-5">
        #1 Pick
      </span>
    )}
  </div>

  <!-- Tagline -->
  <p class="text-sm text-slate-600 leading-snug mb-3 line-clamp-2">{company.tagline}</p>

  <!-- Rating -->
  <div class="flex items-center gap-2 mb-3">
    <StarRating rating={company.rating} />
    <span class="text-sm font-semibold text-slate-900">{company.rating.toFixed(1)}</span>
  </div>

  <!-- Badges -->
  {displayBadges.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-4">
      {displayBadges.map((b: string) => (
        <span class="text-xs bg-blue-50 text-brand-700 border border-blue-100 px-2 py-0.5 rounded font-medium">
          {b}
        </span>
      ))}
      {extraCount > 0 && (
        <span class="text-xs bg-slate-100 text-slate-400 px-2 py-0.5 rounded">
          +{extraCount} more
        </span>
      )}
    </div>
  )}

  <!-- CTAs (pinned to bottom) -->
  <div class="mt-auto flex items-center gap-2 pt-1">
    <a
      href={`/companies/${company.slug}/`}
      class="flex-1 text-center text-sm font-medium text-brand-600 border border-brand-200 rounded-lg py-2 hover:bg-brand-50 transition-colors"
    >
      Read review
    </a>
    <a
      href={company.website}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="text-sm font-medium text-white bg-brand-600 rounded-lg px-4 py-2 hover:bg-brand-700 transition-colors whitespace-nowrap"
    >
      Visit
    </a>
  </div>

</article>
