---
import Base from '../layouts/Base.astro';
import StarRating from '../components/StarRating.astro';
import { companies, getComparisons } from '../data/companies';
import { SITE, NICHE } from '../config';

const comparisons = getComparisons();
const year = new Date().getFullYear();

// Title Case for the homepage <title>/H1 only — NICHE.providersLabel is stored
// lowercase because it also reads correctly mid-sentence (e.g. "36 companies
// reviewed"); this capitalizes it just for the heading-style usage below.
const SMALL_WORDS = new Set(['a', 'an', 'the', 'in', 'at', 'on', 'for', 'of', 'to', 'by', 'with', 'from', 'as', 'and', 'or', 'but', 'nor']);
const titleCase = (str: string) => str.split(' ').map((word, i) => {
  const lower = word.toLowerCase();
  return (i > 0 && SMALL_WORDS.has(lower)) ? lower : lower.charAt(0).toUpperCase() + lower.slice(1);
}).join(' ');
const providersLabelTC = titleCase(NICHE.providersLabel);

// Top-rated companies used in featured profiles section
const featuredProfiles = [...companies].sort((a, b) => b.rating - a.rating).slice(0, 10);

// All unique engagement models across companies — auto-generates table columns so they always match the data
const allEngagementModels = [...new Set(companies.flatMap(c => c.engagementModels))].sort();
---

<Base
  title={`Best ${NICHE.label} ${providersLabelTC} in ${year}`}
  description={`Compare ${NICHE.label} ${NICHE.providersLabel} by pricing, stack, and use case.`}
  canonical={`${SITE.url}/`}
>

  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-zinc-900 to-zinc-950 py-20 sm:py-28">
    <div aria-hidden="true" class="pointer-events-none absolute left-1/2 top-0 -translate-x-1/2 w-[44rem] h-[44rem] rounded-full bg-brand-500/20 blur-3xl"></div>
    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-zinc-50 leading-tight mb-4">
        Best {NICHE.label} {providersLabelTC} in {year}
      </h1>
      <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto mb-6">
        Independent reviews of {companies.length} {NICHE.providersLabel} selected for verified delivery track records, technical expertise, and transparent pricing data. Updated {SITE.lastReviewed}.
      </p>
      <div class="flex flex-wrap gap-3 justify-center mb-6">
        <a href="#comparison-table" class="bg-brand-500 text-zinc-950 font-semibold px-6 py-3 rounded-lg hover:bg-brand-400 transition-colors">
          Compare all {NICHE.providersLabel}
        </a>
      </div>
      <div class="flex flex-wrap gap-3 justify-center text-xs text-zinc-400">
        <span class="bg-white/5 border border-white/10 backdrop-blur-sm px-3 py-1 rounded-full">{companies.length} {NICHE.providersLabel} reviewed</span>
        <span class="bg-white/5 border border-white/10 backdrop-blur-sm px-3 py-1 rounded-full">Updated {SITE.lastReviewed}</span>
        <span class="bg-white/5 border border-white/10 backdrop-blur-sm px-3 py-1 rounded-full">Independent editorial</span>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">

    <!-- QUICK ANSWER BOX -->
    <!-- TODO: Update bullet list below with the most useful buyer-intent recommendations for your niche -->
    <div class="bg-brand-900/30 border border-brand-800 rounded-xl p-6 mb-12">
      <h2 class="text-lg font-bold text-zinc-50 mb-3">Which {NICHE.label} {NICHE.providerLabel} is best?</h2>
      <p class="text-sm text-zinc-300 mb-3">Short answer: the right choice depends on your project size, budget, and specific requirements.</p>
      <ul class="space-y-2 text-sm text-zinc-200">
        {featuredProfiles.slice(0, 6).map(c => (
          <li>
            <span class="font-semibold">Best for {c.bestFor.split(' ').slice(0, 4).join(' ').toLowerCase().replace(/,$/, '')}:</span>{' '}
            <a href={`/companies/${c.slug}/`} class="text-brand-400 hover:underline">{c.name}</a>
            {' '}— {c.primaryDifferentiator}
          </li>
        ))}
      </ul>
    </div>

    <!-- TABLE 1: MASTER COMPARISON -->
    <section id="comparison-table" class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-2">How do the top {NICHE.label} {NICHE.providersLabel} compare?</h2>
      <p class="text-zinc-300 mb-6 text-sm">The table below covers all {companies.length} reviewed {NICHE.providersLabel}.</p>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">Company</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 min-w-[260px]">Best for</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">Pricing model</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">Min. engagement</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">Rating</th>
            </tr>
          </thead>
          <tbody>
            {companies.map((c, i) => (
              <tr class={`border-b border-zinc-800 hover:bg-zinc-900 transition-colors ${c.featured ? 'border-l-4 border-l-brand-500 bg-brand-900/40' : ''}`}>
                <td class="px-4 py-3 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <a href={`/companies/${c.slug}/`} class="font-semibold text-brand-400 hover:underline">{c.name}</a>
                    {c.featured && <span class="text-xs bg-brand-500 text-zinc-950 px-2 py-0.5 rounded-full">Editor's pick</span>}
                  </div>
                </td>
                <td class="px-4 py-3 text-zinc-300">{c.bestFor}</td>
                <td class="px-4 py-3 text-zinc-300 whitespace-nowrap">{c.pricingModel}</td>
                <td class="px-4 py-3 text-zinc-300 whitespace-nowrap">{c.minimumEngagement}</td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <div class="flex items-center gap-1.5">
                    <StarRating rating={c.rating} />
                    <span class="font-semibold text-zinc-50">{c.rating.toFixed(1)}</span>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- SEO PROSE 1: WHAT MAKES A GOOD PROVIDER -->
    <!-- TODO: Replace placeholder prose with content specific to your niche -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-4">What makes a good {NICHE.label} {NICHE.providerLabel}?</h2>
      <div class="prose-custom max-w-none text-sm text-zinc-200 space-y-4">
        <p>The single most important distinction is whether {NICHE.label} is the firm's core business or a capability added to an existing portfolio. Specialist firms built their teams, tooling, and delivery workflows around {NICHE.label} from the start. Generalist firms that added a {NICHE.label} practice often staff it with people transitioning from other roles; the delivery quality gap shows most clearly in production, not in demos.</p>
        <p>Technical depth is a reliable proxy for expertise. A firm that can discuss the specific trade-offs between different approaches and name the tools they used on their last three production projects has built real systems. A firm that describes its approach in generic marketing terms has not demonstrated the same specificity. Ask vendors which specific tools or techniques they used on their last three projects and why.</p>
        <p>The engagement model shapes the project's risk profile as much as the technical approach. Fixed-price contracts work when requirements are well-defined; they create problems when they are not. The best due diligence question: can you show a case study where you delivered a complete project to production, including how you handled issues after launch?</p>
      </div>
    </section>

    <!-- TABLE: TECH STACK BY COMPANY -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-2">What tech stack does each {NICHE.providerLabel} use?</h2>
      <p class="text-zinc-300 mb-6 text-sm">Short answer: specialists typically cover more tools than generalists. Check each profile for full tech stack details.</p>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">Company</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Primary tech stack</th>
            </tr>
          </thead>
          <tbody>
            {companies.map((c, i) => (
              <tr class={`border-b border-zinc-800 hover:bg-zinc-900 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 font-semibold"><a href={`/companies/${c.slug}/`} class="text-brand-400 hover:underline">{c.name}</a></td>
                <td class="px-4 py-3 text-zinc-300">{c.techStack.slice(0, 5).join(', ')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- HOW WE SELECTED -->
    <!-- TODO: Replace these criteria with criteria relevant to your niche -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-4">How we selected these {NICHE.label} {NICHE.providersLabel}</h2>
      <p class="text-zinc-300 mb-3 text-sm">Each {NICHE.providerLabel} in this list was selected based on verifiable signals, not marketing claims. The criteria used for selection in {year} are:</p>
      <ul class="list-disc list-inside space-y-2 text-sm text-zinc-300">
        <li><strong>Verified delivery track record:</strong> Named case studies or independently confirmed client references in {NICHE.label} projects</li>
        <li><strong>Technical specificity:</strong> Demonstrated use of named tools and frameworks; not just generic claims</li>
        <li><strong>Engagement model transparency:</strong> At least one public or disclosed engagement model with enough pricing context to plan a project</li>
        <li><strong>Team composition:</strong> Evidence of dedicated specialists, not a repositioned generalist team</li>
        <li><strong>Reviews and ratings:</strong> Where available, used as a secondary signal alongside editorial assessment</li>
      </ul>
    </section>

    <!-- COMPANY PROFILES -->
    <section id="all-profiles" class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-2">Best {NICHE.label} {NICHE.providersLabel} in {year}</h2>
      <p class="text-zinc-300 mb-8 text-sm">Featured profiles for the top-rated {NICHE.providersLabel}. Full reviews available for all {companies.length} {NICHE.providersLabel} via their profile pages.</p>
      <div class="space-y-8">
        {featuredProfiles.map((c, i) => (
          <div class={`border rounded-xl p-6 ${c.featured ? 'border-brand-700 bg-brand-900/30' : 'border-zinc-700'}`}>
            <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
              <div>
                <div class="flex items-center gap-3 mb-1">
                  <h3 class="text-xl font-bold text-zinc-50">
                    <a href={`/companies/${c.slug}/`} class="hover:text-brand-400">{i + 1}. {c.name}</a>
                  </h3>
                  {c.featured && <span class="text-xs bg-brand-500 text-zinc-950 px-2 py-0.5 rounded-full shrink-0">Editor's pick</span>}
                </div>
                <p class="text-sm text-zinc-400 italic">{c.tagline}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <StarRating rating={c.rating} />
                <span class="font-bold text-zinc-50">{c.rating.toFixed(1)}</span>
              </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4 text-xs text-zinc-300">
              <div><span class="font-semibold text-zinc-400 block">Founded</span>{c.founded}</div>
              <div><span class="font-semibold text-zinc-400 block">HQ</span>{c.hq}</div>
              <div><span class="font-semibold text-zinc-400 block">Team size</span>{c.teamSize}</div>
              <div><span class="font-semibold text-zinc-400 block">Min. engagement</span>{c.minimumEngagement}</div>
            </div>

            <p class="text-sm text-zinc-200 mb-4">{c.description}</p>

            <div class="flex flex-wrap gap-1.5 mb-4">
              {c.techStack.slice(0, 6).map(t => (
                <span class="text-xs bg-zinc-800 text-zinc-300 px-2 py-0.5 rounded">{t}</span>
              ))}
            </div>

            <div class="grid sm:grid-cols-2 gap-4 mb-4 text-sm">
              <div>
                <p class="font-semibold text-zinc-200 mb-1">Advantages</p>
                <ul class="space-y-1">
                  {c.pros.slice(0, 3).map(p => (
                    <li class="flex items-start gap-1.5 text-zinc-300"><span class="text-green-400 font-bold shrink-0">+</span>{p}</li>
                  ))}
                </ul>
              </div>
              <div>
                <p class="font-semibold text-zinc-200 mb-1">Things to consider</p>
                <ul class="space-y-1">
                  {c.cons.map(con => (
                    <li class="flex items-start gap-1.5 text-zinc-300"><span class="text-red-400 font-bold shrink-0">-</span>{con}</li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="flex items-center justify-between flex-wrap gap-3">
              <p class="text-xs text-zinc-400"><span class="font-semibold">Best for:</span> {c.bestFor}</p>
              <div class="flex gap-2">
                <a href={`/companies/${c.slug}/`} class="text-sm font-semibold text-brand-400 hover:underline">Full review</a>
                <span class="text-zinc-600">|</span>
                <a href={c.website} target="_blank" rel="noopener noreferrer nofollow" class="text-sm font-semibold text-zinc-300 hover:text-brand-400">Visit website</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- TABLE 2: BY USE CASE -->
    <!-- TODO: Replace the placeholder rows below with real use-case-to-company mappings for your niche.
         Each row should map a specific buyer use case to the best-fit company with a brief reason. -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-2">Best {NICHE.label} {NICHE.providersLabel} by use case</h2>
      <p class="text-zinc-300 mb-6 text-sm">Short answer: the best {NICHE.providerLabel} depends on your specific use case. The table below maps common use cases to the most suitable firms in {year}.</p>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Use case</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Recommended {NICHE.providerLabel}</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Why</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">Min. engagement</th>
            </tr>
          </thead>
          <tbody>
            {companies.slice(0, 7).map((c, i) => (
              <tr class={`border-b border-zinc-800 hover:bg-zinc-900 ${i % 2 === 1 ? 'bg-zinc-900/50' : ''}`}>
                <td class="px-4 py-3 font-medium text-zinc-100">{c.useCases[0] ?? 'TODO: Add use case'}</td>
                <td class="px-4 py-3"><a href={`/companies/${c.slug}/`} class="text-brand-400 hover:underline">{c.name}</a></td>
                <td class="px-4 py-3 text-zinc-300">{c.primaryDifferentiator}</td>
                <td class="px-4 py-3 text-zinc-300">{c.minimumEngagement}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- TABLE 3: HOW TO CHOOSE -->
    <!-- TODO: Update criteria to match your niche's key evaluation dimensions -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-2">How to choose a {NICHE.label} {NICHE.providerLabel}</h2>
      <p class="text-zinc-300 mb-6 text-sm">Short answer: evaluate specialisation depth, technical coverage, delivery ownership model, and engagement model fit before shortlisting vendors.</p>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Criterion</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Why it matters</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">What to check</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Red flag</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900">
              <td class="px-4 py-3 font-medium text-zinc-100">Specialisation depth</td>
              <td class="px-4 py-3 text-zinc-300">Generalist firms repurposing teams produce slower, lower-quality results</td>
              <td class="px-4 py-3 text-zinc-300">Is {NICHE.label} the firm's core business? What share of team is dedicated?</td>
              <td class="px-4 py-3 text-zinc-300">Practice added recently to a legacy firm with no track record</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900 bg-zinc-900/50">
              <td class="px-4 py-3 font-medium text-zinc-100">Technical coverage</td>
              <td class="px-4 py-3 text-zinc-300">The right tools depend on your project; vendors should cover multiple options</td>
              <td class="px-4 py-3 text-zinc-300">Which specific tools do they use in production projects?</td>
              <td class="px-4 py-3 text-zinc-300">Locked into one vendor or tool with no flexibility</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900">
              <td class="px-4 py-3 font-medium text-zinc-100">Delivery ownership</td>
              <td class="px-4 py-3 text-zinc-300">Staffing platforms require you to provide direction; delivery firms own outcomes</td>
              <td class="px-4 py-3 text-zinc-300">Is this a fixed-output contract or a time-and-materials team?</td>
              <td class="px-4 py-3 text-zinc-300">Firm presents staffing as delivery without clarifying the distinction</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900 bg-zinc-900/50">
              <td class="px-4 py-3 font-medium text-zinc-100">Production experience</td>
              <td class="px-4 py-3 text-zinc-300">Building a prototype is different from running a production system</td>
              <td class="px-4 py-3 text-zinc-300">Request case studies showing post-launch monitoring and iteration</td>
              <td class="px-4 py-3 text-zinc-300">Portfolio shows only demos and PoCs, no production systems</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900">
              <td class="px-4 py-3 font-medium text-zinc-100">Engagement model fit</td>
              <td class="px-4 py-3 text-zinc-300">A fixed-price project on an undefined scope will lead to overruns</td>
              <td class="px-4 py-3 text-zinc-300">Does the engagement model match your requirement certainty?</td>
              <td class="px-4 py-3 text-zinc-300">Vendor pushes fixed-price on a poorly defined scope</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- SEO PROSE 2 -->
    <!-- TODO: Replace placeholder with niche-specific buyer context -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-4">{NICHE.label} in {year}: what buyers should know</h2>
      <div class="prose-custom max-w-none text-sm text-zinc-200 space-y-4">
        <p>{NICHE.label} has matured significantly. The market has bifurcated: a small number of specialist firms with deep expertise, and a much larger number of generalist firms with newly formed {NICHE.label} practices of varying depth. The delivery quality gap between the two types shows most clearly in production, not in demos or proposals.</p>
        <p>Projects cost more than most initial estimates. Scope, integration complexity, and ongoing operational costs all affect total project cost beyond the initial build. A working prototype is not a production system; the difference includes observability tooling, performance optimisation, fallback handling, and a feedback loop for iteration. Buyers who budget only for the prototype often find themselves renegotiating before launch.</p>
        <p>Custom development makes more sense than off-the-shelf tools when the use case requires proprietary data access, complex multi-step logic, or deep integration with internal systems that lack standard connectors. A capable partner will recommend the right approach for your specific use case rather than defaulting to one solution for all projects.</p>
      </div>
    </section>

    <!-- TABLE 9: ENGAGEMENT MODELS BY COMPANY — columns auto-generated from data -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-2">Which engagement models does each {NICHE.providerLabel} offer?</h2>
      <p class="text-zinc-300 mb-6 text-sm">Short answer: most {NICHE.providersLabel} offer more than one engagement model. Use this table to filter by your preferred structure.</p>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Company</th>
              {allEngagementModels.map(m => (
                <th class="text-center px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">{m}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {companies.map((c, i) => (
              <tr class={`border-b border-zinc-800 hover:bg-zinc-900 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 font-semibold"><a href={`/companies/${c.slug}/`} class="text-brand-400 hover:underline">{c.name}</a></td>
                {allEngagementModels.map(m => (
                  <td class={`px-4 py-3 text-center font-semibold ${c.engagementModels.includes(m) ? 'text-green-400' : 'text-zinc-600'}`}>
                    {c.engagementModels.includes(m) ? '✓' : '–'}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- TABLE 4: PRICING -->
    <!-- TODO: Update pricing ranges for your niche -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-zinc-50 mb-2">{NICHE.label} pricing in {year}</h2>
      <p class="text-zinc-300 mb-6 text-sm">Short answer: pricing varies by scope and provider. Contact each {NICHE.providerLabel} directly for project-specific quotes.</p>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Engagement model</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Typical cost range</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Timeline</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Best for</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900">
              <td class="px-4 py-3 font-medium text-zinc-100">Fixed project</td>
              <td class="px-4 py-3 text-zinc-300">From $10K</td>
              <td class="px-4 py-3 text-zinc-300">4–20 weeks</td>
              <td class="px-4 py-3 text-zinc-300">Defined ML use cases with clear inputs and expected outputs</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900 bg-zinc-900/50">
              <td class="px-4 py-3 font-medium text-zinc-100">Retainer</td>
