---
import Base from '../../layouts/Base.astro';
import StarRating from '../../components/StarRating.astro';
import { companies, getComparisons } from '../../data/companies';
import type { Company } from '../../data/companies';
import { SITE, NICHE } from '../../config';

export function getStaticPaths() {
  return companies.map(c => ({ params: { slug: c.slug }, props: { company: c } }));
}

interface Props { company: Company }
const { company } = Astro.props;

const alternatives = companies
  .filter(c => c.slug !== company.slug)
  .sort((a, b) => b.rating - a.rating);

const allComparisons = getComparisons();

const canonical = `${SITE.url}/alternatives/${company.slug}/`;
const pageTitle = `Best ${company.name} alternatives (${new Date().getFullYear()})`;
const pageDesc = `Compare the top ${company.name} alternatives for ${NICHE.label}. Side-by-side analysis of ${companies.length - 1} options.`;
---

<Base title={pageTitle} description={pageDesc} canonical={canonical}>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="text-xs text-zinc-500 mb-6 flex items-center gap-1.5">
      <a href="/" class="hover:text-brand-400">Home</a>
      <span>›</span>
      <span class="text-zinc-500">Alternatives</span>
      <span>›</span>
      <span class="text-zinc-300">{company.name} alternatives</span>
    </nav>

    <!-- Hero -->
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-zinc-50 mb-3">Best {company.name} alternatives in {new Date().getFullYear()}</h1>
      <p class="text-zinc-300 text-lg mb-2">
        {company.name} is {company.tagline.toLowerCase()}.
        Teams looking for alternatives typically seek different pricing structures, technical specialisations, or coverage approaches.
        {alternatives.length > 0 && alternatives[0].primaryDifferentiator.toLowerCase() + '.'}
      </p>
      <p class="text-zinc-300">
        The {alternatives.length} alternatives below are all top-rated {NICHE.label} {NICHE.providersLabel} with verified delivery records. Updated {SITE.lastReviewed}.
      </p>
    </div>

    <!-- Comparison summary table -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">How {company.name} alternatives compare</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Company</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Best for</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Key difference from {company.name}</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 whitespace-nowrap">Pricing model</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Rating</th>
            </tr>
          </thead>
          <tbody>
            {alternatives.map((alt, i) => (
              <tr class={`border-b border-zinc-800 hover:bg-zinc-900 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3">
                  <a href={`/companies/${alt.slug}/`} class="font-semibold text-brand-400 hover:underline">{alt.name}</a>
                </td>
                <td class="px-4 py-3 text-zinc-300 text-xs">{alt.bestFor.split(' ').slice(0, 8).join(' ')}...</td>
                <td class="px-4 py-3 text-zinc-300 text-xs">{alt.primaryDifferentiator}</td>
                <td class="px-4 py-3 text-zinc-300 text-xs">{alt.pricingModel}</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1">
                    <span class="font-semibold text-zinc-50">{alt.rating.toFixed(1)}</span>
                    <span class="text-zinc-500 text-xs">/ 5</span>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Individual alternative profiles -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-zinc-50 mb-6">Top {company.name} alternatives in {new Date().getFullYear()}</h2>
      <div class="space-y-8">
        {alternatives.map((alt, i) => {
          const compSlug = allComparisons.find(
            c => (c.slug1 === company.slug && c.slug2 === alt.slug) ||
                 (c.slug2 === company.slug && c.slug1 === alt.slug)
          )?.slug;
          return (
            <div class="border border-zinc-700 rounded-xl p-6">
              <div class="flex items-start justify-between flex-wrap gap-4 mb-3">
                <div>
                  <h2 class="text-xl font-bold text-zinc-50 mb-1">
                    <a href={`/companies/${alt.slug}/`} class="hover:text-brand-400">{i + 1}. {alt.name}</a>
                  </h2>
                  <p class="text-sm text-zinc-400 italic">{alt.tagline}</p>
                </div>
                <div class="flex items-center gap-2">
                  <StarRating rating={alt.rating} />
                  <span class="font-bold text-zinc-50">{alt.rating.toFixed(1)}</span>
                </div>
              </div>

              <p class="text-sm text-zinc-200 mb-4">{alt.description}</p>

              <p class="text-sm text-zinc-200 mb-4">
                <strong>How it differs from {company.name}:</strong> {alt.primaryDifferentiator}.
                While {company.name} excels at {company.primaryDifferentiator.toLowerCase()},
                {alt.name} is better for {alt.bestFor.charAt(0).toLowerCase() + alt.bestFor.slice(1)}.
              </p>

              <div class="overflow-x-auto rounded-lg border border-zinc-700 mb-4">
                <table class="w-full text-xs">
                  <tbody>
                    <tr class="border-b border-zinc-800">
                      <td class="px-3 py-2 font-semibold text-zinc-400 w-32">Founded</td>
                      <td class="px-3 py-2 text-zinc-200">{alt.founded}</td>
                      <td class="px-3 py-2 font-semibold text-zinc-400 w-32">HQ</td>
                      <td class="px-3 py-2 text-zinc-200">{alt.hq}</td>
                    </tr>
                    <tr class="border-b border-zinc-800 bg-zinc-900/50">
                      <td class="px-3 py-2 font-semibold text-zinc-400">Team</td>
                      <td class="px-3 py-2 text-zinc-200">{alt.teamSize}</td>
                      <td class="px-3 py-2 font-semibold text-zinc-400">Rating</td>
                      <td class="px-3 py-2 text-zinc-200">{alt.rating.toFixed(1)} / 5</td>
                    </tr>
                    <tr>
                      <td class="px-3 py-2 font-semibold text-zinc-400">Min. engagement</td>
                      <td class="px-3 py-2 text-zinc-200">{alt.minimumEngagement}</td>
                      <td class="px-3 py-2 font-semibold text-zinc-400">Pricing</td>
                      <td class="px-3 py-2 text-zinc-200">{alt.pricingModel}</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <div class="flex flex-wrap gap-2">
                <a href={`/companies/${alt.slug}/`} class="text-sm font-semibold text-brand-400 border border-brand-800 px-4 py-1.5 rounded-lg hover:bg-brand-900/30 transition-colors">
                  Read full review
                </a>
                {compSlug && (
                  <a href={`/comparisons/${compSlug}/`} class="text-sm font-semibold text-zinc-300 border border-zinc-600 px-4 py-1.5 rounded-lg hover:border-brand-500 hover:text-brand-400 transition-colors">
                    Compare {alt.name} vs {company.name}
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- How to choose -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">How to choose between {company.name} and its alternatives</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Criterion</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Choose {company.name} if</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Choose an alternative if</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900">
              <td class="px-4 py-3 font-medium text-zinc-100">Budget</td>
              <td class="px-4 py-3 text-zinc-300">Your budget aligns with {company.minimumEngagement} minimum engagement</td>
              <td class="px-4 py-3 text-zinc-300">You need a lower minimum — check the alternatives table above for the lowest-minimum option</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900 bg-zinc-900/50">
              <td class="px-4 py-3 font-medium text-zinc-100">Team size needs</td>
              <td class="px-4 py-3 text-zinc-300">You need a {company.teamSize} team with focused {NICHE.label} delivery</td>
              <td class="px-4 py-3 text-zinc-300">You need a much larger team or a multi-region programme — check alternatives by team size</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900">
              <td class="px-4 py-3 font-medium text-zinc-100">Specialisation</td>
              <td class="px-4 py-3 text-zinc-300">{company.primaryDifferentiator}</td>
              <td class="px-4 py-3 text-zinc-300">You need a different specialisation — check the alternatives' primary differentiators above</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900 bg-zinc-900/50">
              <td class="px-4 py-3 font-medium text-zinc-100">Engagement model</td>
              <td class="px-4 py-3 text-zinc-300">{company.pricingModel} fits your project structure</td>
              <td class="px-4 py-3 text-zinc-300">You need a different model (e.g. time-and-materials or dedicated team) — compare engagement models above</td>
            </tr>
            <tr class="border-b border-zinc-800 hover:bg-zinc-900">
              <td class="px-4 py-3 font-medium text-zinc-100">Industry vertical</td>
              <td class="px-4 py-3 text-zinc-300">You work in {company.industries.slice(0, 2).join(' or ')}</td>
              <td class="px-4 py-3 text-zinc-300">You need deep expertise in a different vertical — check each alternative's industry list</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-6">{company.name} alternatives FAQ</h2>
      <div class="space-y-5">
        <div class="border-b border-zinc-800 pb-5">
          <h3 class="font-semibold text-zinc-50 mb-2">What is the best alternative to {company.name}?</h3>
          <p class="text-sm text-zinc-300 mb-2">
            The best alternative depends on your use case and budget. The top three alternatives by rating are:
          </p>
          <ul class="text-sm text-zinc-300 space-y-1">
            {alternatives.slice(0, 3).map(alt => (
              <li><a href={`/companies/${alt.slug}/`} class="text-brand-400 hover:underline">{alt.name}</a>: {alt.primaryDifferentiator.toLowerCase()}</li>
            ))}
          </ul>
        </div>
        <div class="border-b border-zinc-800 pb-5">
          <h3 class="font-semibold text-zinc-50 mb-2">How does {company.name} compare to {alternatives[0]?.name}?</h3>
          <p class="text-sm text-zinc-300">
            {company.name} focuses on {company.primaryDifferentiator.toLowerCase()}.
            {alternatives[0]?.name} is differentiated by {alternatives[0]?.primaryDifferentiator.toLowerCase()}.
            {alternatives[0]?.name} is best for {alternatives[0] ? alternatives[0].bestFor.charAt(0).toLowerCase() + alternatives[0].bestFor.slice(1) : ''}.
            {company.name} is best for {company.bestFor.charAt(0).toLowerCase() + company.bestFor.slice(1)}.
          </p>
        </div>
        <div class="pb-5">
          <h3 class="font-semibold text-zinc-50 mb-2">Is there a cheaper alternative to {company.name}?</h3>
          <p class="text-sm text-zinc-300">
            {company.minimumEngagement !== 'Not disclosed'
              ? `${company.name} starts at ${company.minimumEngagement}. `
              : `${company.name} does not disclose minimum engagement publicly. `}
            Check the alternatives table above — the lowest-minimum option is listed first when sorted by minimum engagement.
            Some alternatives may offer lower entry points or flexible hourly/retainer models that better suit constrained budgets.
          </p>
        </div>
      </div>
    </section>

    <p class="text-xs text-zinc-500 border-t border-zinc-800 pt-4">
      Last reviewed: {SITE.lastReviewed}. Verify all details directly with each {NICHE.providerLabel} before making a decision.
    </p>

  </div>
</Base>
