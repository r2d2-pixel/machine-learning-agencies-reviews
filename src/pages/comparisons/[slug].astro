---
import Base from '../../layouts/Base.astro';
import StarRating from '../../components/StarRating.astro';
import { companies, getComparisons } from '../../data/companies';
import type { Company } from '../../data/companies';
import { SITE, NICHE } from '../../config';

export function getStaticPaths() {
  return getComparisons().map(c => ({
    params: { slug: c.slug },
    props: { slug1: c.slug1, slug2: c.slug2 },
  }));
}

interface Props { slug1: string; slug2: string }
const { slug1, slug2 } = Astro.props;

const c1 = companies.find(c => c.slug === slug1)!;
const c2 = companies.find(c => c.slug === slug2)!;

const slug = `${slug1}-vs-${slug2}`;
const canonical = `${SITE.url}/comparisons/${slug}/`;
const pageTitle = `${c1.name} vs ${c2.name} (${new Date().getFullYear()}): ${NICHE.label} comparison`;
const pageDesc = `${c1.name} vs ${c2.name}: full side-by-side comparison of pricing, services, tech stack, and use cases.`;

// Related comparisons: all comparisons involving either company, excluding this one
const allComparisons = getComparisons();
const related = allComparisons.filter(c =>
  c.slug !== slug &&
  (c.slug1 === slug1 || c.slug2 === slug1 || c.slug1 === slug2 || c.slug2 === slug2)
).slice(0, 6);

function hasCap(company: Company, cap: string): string {
  const checks: Record<string, (c: Company) => boolean> = {
    'Custom ML development': c => c.badges.some(b => b.includes('custom-ml')),
    'Deep learning':         c => c.badges.some(b => b.includes('deep-learning')),
    'NLP / Text analytics':  c => c.badges.some(b => b.includes('nlp')),
    'Computer vision':       c => c.badges.some(b => b.includes('computer-vision')),
    'MLOps & deployment':    c => c.badges.some(b => b.includes('mlops')),
    'Generative AI':         c => c.badges.some(b => b.includes('generative-ai')),
    'AI strategy':           c => c.badges.some(b => b.includes('ai-strategy')),
    'Staff augmentation':    c => c.badges.some(b => b.includes('staff-aug')),
    'Fixed-price projects':  c => c.engagementModels.some(m => m.toLowerCase().includes('fixed')),
    'Dedicated team model':  c => c.engagementModels.some(m => m.toLowerCase().includes('dedicated')),
  };
  return checks[cap]?.(company) ? '✓' : '✗';
}

const allTech = ['Python', 'TensorFlow', 'PyTorch', 'AWS', 'Kubernetes', 'Databricks', 'MLflow'];

function hasTech(company: Company, tech: string): string {
  return company.techStack.some(t => t.toLowerCase().includes(tech.toLowerCase())) ? '✓' : 'N/A';
}

// Winner logic: basic heuristic
const winner = c1.rating >= c2.rating ? c1 : c2;
const runner = winner.slug === c1.slug ? c2 : c1;

// Use-case table data — derived in frontmatter to avoid ?? in JSX
// TODO: Replace with use cases specific to your niche
const useCaseRows = [
  c1.useCases[0] || 'Use case 1',
  c1.useCases[1] || 'Use case 2',
  c2.useCases[0] || 'Use case 3',
  c2.useCases[1] || 'Use case 4',
  'Fixed-price build',
  'Staff augmentation',
].filter((v, i, a) => a.indexOf(v) === i).slice(0, 6);

// Decision matrix — precomputed in frontmatter to keep JSX free of complex regex + ternary combinations
const minEngRow = (() => {
  const na = parseInt(c1.minimumEngagement.replace(/\D/g, ''));
  const nb = parseInt(c2.minimumEngagement.replace(/\D/g, ''));
  if (c1.minimumEngagement === 'Not disclosed' || c2.minimumEngagement === 'Not disclosed' || isNaN(na) || isNaN(nb)) {
    return `Compare: ${c1.name} (${c1.minimumEngagement}) vs ${c2.name} (${c2.minimumEngagement})`;
  }
  return na <= nb ? c1.name : c2.name;
})();

const decisionRows: [string, string][] = [
  [`You need full-ownership delivery on a defined project scope`,
   c1.engagementModels.some(m => m.toLowerCase().includes('fixed')) ? c1.name : c2.engagementModels.some(m => m.toLowerCase().includes('fixed')) ? c2.name : `Both offer fixed-price models`],
  [`You need a large dedicated team for an ongoing programme`,
   c1.engagementModels.some(m => m.toLowerCase().includes('dedicated')) ? c1.name : c2.engagementModels.some(m => m.toLowerCase().includes('dedicated')) ? c2.name : `Check each company's engagement model`],
  [`Your budget is at the lower end`, minEngRow],
  [`You need specialist depth in a specific vertical`,
   c1.industries.length >= c2.industries.length ? c1.name : c2.name],
  [`You need staff augmentation or team extension`,
   c1.badges.some(b => b.toLowerCase().includes('staff')) ? c1.name : c2.badges.some(b => b.toLowerCase().includes('staff')) ? c2.name : `Neither; consider alternatives that offer staff aug`],
  [`You need consulting before committing to a build`,
   c1.badges.some(b => b.toLowerCase().includes('consult')) ? c1.name : c2.badges.some(b => b.toLowerCase().includes('consult')) ? c2.name : `Both may offer discovery engagements`],
];
---

<Base title={pageTitle} description={pageDesc} canonical={canonical}>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="text-xs text-zinc-500 mb-6 flex items-center gap-1.5">
      <a href="/" class="hover:text-brand-400">Home</a>
      <span>›</span>
      <span class="text-zinc-500">Comparisons</span>
      <span>›</span>
      <span class="text-zinc-300">{c1.name} vs {c2.name}</span>
    </nav>

    <!-- H1 -->
    <h1 class="text-3xl sm:text-4xl font-bold text-zinc-50 mb-2">
      {c1.name} vs {c2.name}: full comparison for {new Date().getFullYear()}
    </h1>
    <p class="text-xs text-zinc-500 mb-6">Last updated: {SITE.lastReviewed}</p>

    <!-- Quick verdict -->
    <div class="bg-brand-900/30 border border-brand-800 rounded-xl p-5 mb-10">
      <p class="font-semibold text-zinc-50 mb-1">Quick verdict</p>
      <p class="text-sm text-zinc-200">
        <a href={`/companies/${winner.slug}/`} class="font-bold text-brand-400">{winner.name}</a> ({winner.rating.toFixed(1)}/5)
        edges ahead of <a href={`/companies/${runner.slug}/`} class="text-brand-400">{runner.name}</a> ({runner.rating.toFixed(1)}/5)
        overall. {winner.name} is the better choice for {winner.bestFor.charAt(0).toLowerCase() + winner.bestFor.slice(1)}.
        {runner.name} is the stronger option for {runner.bestFor.charAt(0).toLowerCase() + runner.bestFor.slice(1)}.
        The right choice depends on your project size, budget, and required tech stack.
      </p>
    </div>

    <!-- TABLE 1: Head-to-head summary -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">{c1.name} vs {c2.name}: head-to-head summary</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200 w-1/3">Criterion</th>
              <th class="text-left px-4 py-3 font-semibold text-brand-300">{c1.name}</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">{c2.name}</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Founded', String(c1.founded), String(c2.founded)],
              ['HQ', c1.hq, c2.hq],
              ['Team size', c1.teamSize, c2.teamSize],
              ['Rating', `${c1.rating.toFixed(1)} / 5`, `${c2.rating.toFixed(1)} / 5`],
              ['Best for', c1.bestFor, c2.bestFor],
              ['Pricing model', c1.pricingModel, c2.pricingModel],
              ['Min. engagement', c1.minimumEngagement, c2.minimumEngagement],
              ['Primary tech stack', c1.techStack.slice(0, 3).join(', '), c2.techStack.slice(0, 3).join(', ')],
              ['Industries served', c1.industries.join(', '), c2.industries.join(', ')],
            ].map(([criterion, v1, v2], i) => (
              <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 font-medium text-zinc-200">{criterion}</td>
                <td class="px-4 py-3 text-zinc-200">{v1}</td>
                <td class="px-4 py-3 text-zinc-200">{v2}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Overview -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">{c1.name} vs {c2.name}: overview</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="border border-zinc-700 rounded-xl p-5">
          <h3 class="font-bold text-zinc-50 mb-2">{c1.name}</h3>
          <p class="text-sm text-zinc-200">{c1.description}</p>
        </div>
        <div class="border border-zinc-700 rounded-xl p-5">
          <h3 class="font-bold text-zinc-50 mb-2">{c2.name}</h3>
          <p class="text-sm text-zinc-200">{c2.description}</p>
        </div>
      </div>
    </section>

    <!-- TABLE 2: Services and capabilities -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">Services and capabilities: {c1.name} vs {c2.name}</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Capability</th>
              <th class="text-left px-4 py-3 font-semibold text-brand-300">{c1.name}</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">{c2.name}</th>
            </tr>
          </thead>
          <tbody>
            {['Custom ML development', 'Deep learning', 'NLP / Text analytics', 'Computer vision', 'MLOps & deployment', 'Generative AI', 'AI strategy', 'Staff augmentation', 'Fixed-price projects', 'Dedicated team model'].map((cap, i) => (
              <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 font-medium text-zinc-200">{cap}</td>
                <td class={`px-4 py-3 font-semibold ${hasCap(c1, cap) === '✓' ? 'text-green-400' : 'text-red-400'}`}>{hasCap(c1, cap)}</td>
                <td class={`px-4 py-3 font-semibold ${hasCap(c2, cap) === '✓' ? 'text-green-400' : 'text-red-400'}`}>{hasCap(c2, cap)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- TABLE 3: Tech stack -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">Tech stack comparison: {c1.name} vs {c2.name}</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Framework / platform</th>
              <th class="text-left px-4 py-3 font-semibold text-brand-300">{c1.name}</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">{c2.name}</th>
            </tr>
          </thead>
          <tbody>
            {allTech.map((tech, i) => (
              <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 font-medium text-zinc-200">{tech}</td>
                <td class={`px-4 py-3 font-semibold ${hasTech(c1, tech) === '✓' ? 'text-green-400' : 'text-zinc-500'}`}>{hasTech(c1, tech)}</td>
                <td class={`px-4 py-3 font-semibold ${hasTech(c2, tech) === '✓' ? 'text-green-400' : 'text-zinc-500'}`}>{hasTech(c2, tech)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- TABLE 4: Pricing -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">Pricing comparison: {c1.name} vs {c2.name}</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Criterion</th>
              <th class="text-left px-4 py-3 font-semibold text-brand-300">{c1.name}</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">{c2.name}</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Minimum engagement', c1.minimumEngagement, c2.minimumEngagement],
              ['Engagement models', c1.engagementModels.join(', '), c2.engagementModels.join(', ')],
              ['Rate transparency', c1.minimumEngagement !== 'Not disclosed' ? 'Minimum disclosed' : 'Not public', c2.minimumEngagement !== 'Not disclosed' ? 'Minimum disclosed' : 'Not public'],
              ['Price tier', c1.minimumEngagement === '~$200K+' ? 'Enterprise' : c1.minimumEngagement === 'Not disclosed' ? 'Mid-market' : parseInt(c1.minimumEngagement.replace(/\D/g, '')) <= 20000 ? 'Accessible' : 'Mid-market', c2.minimumEngagement === '~$200K+' ? 'Enterprise' : c2.minimumEngagement === 'Not disclosed' ? 'Mid-market' : parseInt(c2.minimumEngagement.replace(/\D/g, '')) <= 20000 ? 'Accessible' : 'Mid-market'],
            ].map(([criterion, v1, v2], i) => (
              <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 font-medium text-zinc-200">{criterion}</td>
                <td class="px-4 py-3 text-zinc-200">{v1}</td>
                <td class="px-4 py-3 text-zinc-200">{v2}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- TABLE 5: Target audience -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">Target audience comparison: {c1.name} vs {c2.name}</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Dimension</th>
              <th class="text-left px-4 py-3 font-semibold text-brand-300">{c1.name}</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">{c2.name}</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Best company size', c1.teamSize.includes('10,000') ? 'Enterprise' : c1.teamSize.includes('1,000') ? 'Mid-market to enterprise' : 'Startup to mid-market', c2.teamSize.includes('10,000') ? 'Enterprise' : c2.teamSize.includes('1,000') ? 'Mid-market to enterprise' : 'Startup to mid-market'],
              ['Best industries', c1.industries.slice(0, 3).join(', '), c2.industries.slice(0, 3).join(', ')],
              ['Best use cases', c1.useCases.slice(0, 2).join(', '), c2.useCases.slice(0, 2).join(', ')],
              ['Typical project type', c1.engagementModels[0], c2.engagementModels[0]],
            ].map(([dim, v1, v2], i) => (
              <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 font-medium text-zinc-200">{dim}</td>
                <td class="px-4 py-3 text-zinc-200">{v1}</td>
                <td class="px-4 py-3 text-zinc-200">{v2}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- TABLE 6: Pros and cons of each -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">{c1.name} vs {c2.name}: pros and cons</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="overflow-x-auto rounded-xl border border-zinc-700">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-zinc-900 border-b border-zinc-700">
                <th class="text-left px-4 py-3 font-semibold text-brand-300" colspan="2">{c1.name}</th>
              </tr>
            </thead>
            <tbody>
              {c1.pros.map((p, i) => (
                <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                  <td class="px-4 py-3 text-green-400 font-bold w-6 align-top">+</td>
                  <td class="px-4 py-3 text-zinc-200">{p}</td>
                </tr>
              ))}
              {c1.cons.map((con, i) => (
                <tr class={`border-b border-zinc-800 ${(c1.pros.length + i) % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                  <td class="px-4 py-3 text-red-400 font-bold w-6 align-top">-</td>
                  <td class="px-4 py-3 text-zinc-200">{con}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="overflow-x-auto rounded-xl border border-zinc-700">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-zinc-900 border-b border-zinc-700">
                <th class="text-left px-4 py-3 font-semibold text-zinc-200" colspan="2">{c2.name}</th>
              </tr>
            </thead>
            <tbody>
              {c2.pros.map((p, i) => (
                <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                  <td class="px-4 py-3 text-green-400 font-bold w-6 align-top">+</td>
                  <td class="px-4 py-3 text-zinc-200">{p}</td>
                </tr>
              ))}
              {c2.cons.map((con, i) => (
                <tr class={`border-b border-zinc-800 ${(c2.pros.length + i) % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                  <td class="px-4 py-3 text-red-400 font-bold w-6 align-top">-</td>
                  <td class="px-4 py-3 text-zinc-200">{con}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Who should choose each -->
    <section class="mb-10">
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <h2 class="text-xl font-bold text-zinc-50 mb-3">Who should choose {c1.name}?</h2>
          <p class="text-sm text-zinc-200 mb-2">{c1.name} is the right choice for {c1.bestFor.charAt(0).toLowerCase() + c1.bestFor.slice(1)}.</p>
          <p class="text-sm text-zinc-200">{c1.primaryDifferentiator}. Minimum engagement starts at {c1.minimumEngagement}. Works best with clients in {c1.industries.join(', ')}.</p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-zinc-50 mb-3">Who should choose {c2.name}?</h2>
          <p class="text-sm text-zinc-200 mb-2">{c2.name} is the right choice for {c2.bestFor.charAt(0).toLowerCase() + c2.bestFor.slice(1)}.</p>
          <p class="text-sm text-zinc-200">{c2.primaryDifferentiator}. Minimum engagement starts at {c2.minimumEngagement}. Works best with clients in {c2.industries.join(', ')}.</p>
        </div>
      </div>
    </section>

    <!-- TABLE 7: Decision matrix -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">Decision matrix: {c1.name} vs {c2.name}</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Your situation</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Recommended choice</th>
            </tr>
          </thead>
          <tbody>
            {decisionRows.map(([situation, choice], i) => (
              <tr class={`border-b border-zinc-800 hover:bg-zinc-900 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                <td class="px-4 py-3 text-zinc-200">{situation}</td>
                <td class="px-4 py-3 font-semibold text-brand-300">{choice}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- TABLE 8: Use case matching -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">Use case fit: {c1.name} vs {c2.name}</h2>
      <div class="overflow-x-auto rounded-xl border border-zinc-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-zinc-900 border-b border-zinc-700">
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Use case</th>
              <th class="text-left px-4 py-3 font-semibold text-brand-300">{c1.name} fit</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">{c2.name} fit</th>
              <th class="text-left px-4 py-3 font-semibold text-zinc-200">Winner</th>
            </tr>
          </thead>
          <tbody>
            {useCaseRows.map((uc, i) => {
              const c1fit = c1.useCases.some(u => u.toLowerCase().includes(uc.split(' ')[0].toLowerCase())) ? 'Strong' : 'Limited';
              const c2fit = c2.useCases.some(u => u.toLowerCase().includes(uc.split(' ')[0].toLowerCase())) ? 'Strong' : 'Limited';
              const w = c1fit === 'Strong' && c2fit !== 'Strong' ? c1.name : c2fit === 'Strong' && c1fit !== 'Strong' ? c2.name : 'Both equally';
              return (
                <tr class={`border-b border-zinc-800 ${i % 2 === 1 ? 'bg-zinc-900/40' : ''}`}>
                  <td class="px-4 py-3 font-medium text-zinc-200">{uc}</td>
                  <td class={`px-4 py-3 font-semibold ${c1fit === 'Strong' ? 'text-green-400' : 'text-zinc-500'}`}>{c1fit}</td>
                  <td class={`px-4 py-3 font-semibold ${c2fit === 'Strong' ? 'text-green-400' : 'text-zinc-500'}`}>{c2fit}</td>
                  <td class="px-4 py-3 text-zinc-200 font-semibold">{w}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Verdict -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-4">Verdict: {c1.name} vs {c2.name}</h2>
      <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-6 mb-4">
        <p class="text-zinc-200 mb-3">
          <strong>{winner.name}</strong> ({winner.rating.toFixed(1)}/5) is the stronger overall choice for most {NICHE.label} projects.
          {winner.primaryDifferentiator}. It is best for {winner.bestFor.charAt(0).toLowerCase() + winner.bestFor.slice(1)}.
        </p>
        <p class="text-zinc-200">
          <strong>{runner.name}</strong> ({runner.rating.toFixed(1)}/5) is the better choice when {runner.bestFor.charAt(0).toLowerCase() + runner.bestFor.slice(1)}.
          If your situation matches those criteria, {runner.name} is a competitive option.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href={`/companies/${c1.slug}/`} class="bg-brand-500 text-zinc-950 font-semibold px-5 py-2.5 rounded-lg hover:bg-brand-400 transition-colors text-sm">
          Read {c1.name} full review
        </a>
        <a href={`/companies/${c2.slug}/`} class="border border-zinc-600 text-zinc-200 font-semibold px-5 py-2.5 rounded-lg hover:border-brand-500 hover:text-brand-400 transition-colors text-sm">
          Read {c2.name} full review
        </a>
      </div>
    </section>

    <!-- Related comparisons -->
    {related.length > 0 && (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-zinc-50 mb-4">Related comparisons</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {related.map(c => {
            const rc1 = companies.find(co => co.slug === c.slug1)!;
            const rc2 = companies.find(co => co.slug === c.slug2)!;
            return (
              <a href={`/comparisons/${c.slug}/`} class="border border-zinc-700 rounded-lg px-3 py-2.5 text-xs font-medium text-zinc-200 hover:border-brand-500 hover:text-brand-400 hover:bg-brand-900/30 transition-colors">
                {rc1.name} vs {rc2.name}
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- FAQ -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-zinc-50 mb-6">{c1.name} vs {c2.name} FAQ</h2>
      <div class="space-y-5">
        <div class="border-b border-zinc-800 pb-5">
          <h3 class="font-semibold text-zinc-50 mb-2">Is {c1.name} better than {c2.name}?</h3>
          <p class="text-sm text-zinc-300">
            {winner.name} ({winner.rating.toFixed(1)}/5) scores higher overall, but "better" depends on your use case.
            {c1.name} is better for {c1.bestFor.charAt(0).toLowerCase() + c1.bestFor.slice(1)}.
            {c2.name} is better for {c2.bestFor.charAt(0).toLowerCase() + c2.bestFor.slice(1)}.
          </p>
        </div>
        <div class="border-b border-zinc-800 pb-5">
          <h3 class="font-semibold text-zinc-50 mb-2">How do {c1.name} and {c2.name} differ in pricing?</h3>
          <p class="text-sm text-zinc-300">
            {c1.name} uses {c1.pricingModel.toLowerCase()} pricing with a minimum engagement of {c1.minimumEngagement}.
            {c2.name} uses {c2.pricingModel.toLowerCase()} pricing with a minimum engagement of {c2.minimumEngagement}.
            Neither firm publishes a full rate card; a discovery call is required for project-specific quotes.
          </p>
        </div>
        <div class="border-b border-zinc-800 pb-5">
          <h3 class="font-semibold text-zinc-50 mb-2">Which is better for enterprise: {c1.name} or {c2.name}?</h3>
          <p class="text-sm text-zinc-300">
            {(parseInt(c1.teamSize.replace(/\D/g,'') || '0') >= parseInt(c2.teamSize.replace(/\D/g,'') || '0') ? c1.name : c2.name)} is the larger team and typically the better enterprise-scale choice.
            For very large programmes, verify team size and compliance coverage directly with each {NICHE.providerLabel} before shortlisting.
          </p>
        </div>
        <div class="pb-5">
          <h3 class="font-semibold text-zinc-50 mb-2">What are the main differences between {c1.name} and {c2.name}?</h3>
          <p class="text-sm text-zinc-300">
            {c1.name}'s primary differentiator is: {c1.primaryDifferentiator.toLowerCase()}.
            {c2.name}'s primary differentiator is: {c2.primaryDifferentiator.toLowerCase()}.
            They also differ in team size ({c1.teamSize} vs {c2.teamSize}), minimum engagement ({c1.minimumEngagement} vs {c2.minimumEngagement}), and primary industries served ({c1.industries.slice(0,2).join(', ')} vs {c2.industries.slice(0,2).join(', ')}).
          </p>
        </div>
      </div>
    </section>

    <p class="text-xs text-zinc-500 border-t border-zinc-800 pt-4">
      Last reviewed: {SITE.lastReviewed}. Verify all details directly with each {NICHE.providerLabel} before making a decision.
    </p>

  </div>
</Base>
