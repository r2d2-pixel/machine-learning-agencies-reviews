---
import Base from '../layouts/Base.astro';
import { SITE, NICHE } from '../config';
---

<Base
  title="Page Not Found"
  description={`The page you're looking for doesn't exist. Browse all ${NICHE.label} ${NICHE.providersLabel} or go back home.`}
>
  <div class="mx-auto max-w-2xl px-4 sm:px-6 text-center py-24">
    <p class="text-6xl font-bold text-brand-200 mb-4">404</p>
    <h1 class="text-2xl font-bold text-slate-900 mb-3">Page not found</h1>
    <p class="text-slate-500 mb-8">
      The page you're looking for doesn't exist or has moved.
      Try browsing {NICHE.providersLabel} or going back to the home page.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/" class="bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-brand-700 transition-colors text-sm">
        Browse all {NICHE.providersLabel}
      </a>
      <a href="/" class="text-brand-600 font-medium text-sm hover:underline self-center">
        ← Home
      </a>
    </div>
  </div>
</Base>
